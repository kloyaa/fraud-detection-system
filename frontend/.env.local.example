# =============================================================================
# RAS Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in values for local development.
# NEVER commit .env.local — it is in .gitignore.
# =============================================================================

# --- Next.js ---
NEXT_PUBLIC_APP_ENV=development

# --- NextAuth.js ---
# Random secret for session encryption. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- Backend API (BFF only — never exposed to browser) ---
# In Docker: http://app:8000
# Local dev without Docker: http://localhost:8000
BACKEND_URL=http://localhost:8000

# --- Keycloak OIDC (staging/prod only — not used with dev credentials provider) ---
# KEYCLOAK_ISSUER=https://keycloak.example.com/realms/ras
# KEYCLOAK_CLIENT_ID=ras-frontend
# KEYCLOAK_CLIENT_SECRET=change-me
