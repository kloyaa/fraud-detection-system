# Production environment file for Docker Compose
# Copy to .env.prod and fill in all required values

# Environment
ENVIRONMENT=production
DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000

# Database (required)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ras_prod

# Redis (required)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Logging
LOG_LEVEL=INFO

# Optional: AWS services (for future Vault integration)
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=arn:aws:kms:...  # Fill in KMS key ARN for secrets encryption
