# Development environment file.
# Copy to .env and configure for local development.
# All values are defaults suitable for docker-compose.

# Environment
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# Database (use docker-compose defaults)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ras_dev

# Redis (use docker-compose defaults)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Kafka (use docker-compose external listener — port 9094)
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Cassandra (use docker-compose defaults)
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=ras_dev

# HashiCorp Vault (dev mode — never use dev-root-token in staging/prod)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# Keycloak OIDC (configure realm + client after first docker-compose up)
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=ras
KEYCLOAK_CLIENT_ID=ras-backend
KEYCLOAK_CLIENT_SECRET=change-me

# Logging
LOG_LEVEL=DEBUG
